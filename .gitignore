# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# local audio library — not committed (user-local)
/songs/

# large video files (kept local; too big for GitHub)
/public/videos/*.mp4
/public/videos/*.mov
/public/videos/*.webm
!/public/videos/.gitkeep
# ...except the compressed demo which ships to Vercel
!/public/videos/dj-set-demo.mp4

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
